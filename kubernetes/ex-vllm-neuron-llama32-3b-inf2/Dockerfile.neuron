FROM public.ecr.aws/neuron/pytorch-inference-neuronx:2.1.2-neuronx-py310-sdk2.20.0-ubuntu20.04

ARG VLLM_REF=v0.6.0

# Build vLLM with Neuron support (based on AWS blog workflow).
RUN git clone https://github.com/vllm-project/vllm.git /vllm
WORKDIR /vllm
RUN git checkout ${VLLM_REF}

ENV VLLM_TARGET_DEVICE=neuron

RUN python3 -m pip install -U -r requirements-neuron.txt
RUN python3 -m pip install .
# vLLM 0.6.0 is not compatible with Transformers 5.x / latest tokenizers.
# Keep a known-good pair for Llama 3.1 on this stack.
RUN python3 -m pip install --no-cache-dir "transformers==4.44.2" "tokenizers==0.19.1"

# Extend block-size choices as in AWS reference.
RUN sed -i "/parser.add_argument('--block-size',/ {N;N;N;N;N;s/\\[8, 16, 32\\]/[8, 16, 32, 128, 256, 512, 1024, 2048, 4096, 8192]/}" vllm/engine/arg_utils.py

RUN python3 -m pip install ray
# Keep Triton aligned with vLLM 0.6 Neuron path. Newer Triton versions
# can remove symbols used by vLLM (for example default_cache_dir).
RUN python3 -m pip install --no-cache-dir "triton==3.0.0"
# outlines (bundled with vLLM) requires pyairports but doesn't declare it.
RUN python3 -m pip install --no-cache-dir pyairports

ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
