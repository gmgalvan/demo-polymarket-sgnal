{
  "annotations": { "list": [] },
  "description": "NVIDIA GPU metrics from DCGM Exporter — utilization, memory, temperature, power, ECC errors",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Reported GPU Utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL{instance=~\"$instance\"}",
          "legendFormat": "GPU {{gpu}} — {{instance}}"
        }
      ]
    },
    {
      "title": "GPU Memory Used (GiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes"
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} / 1024",
          "legendFormat": "Used — GPU {{gpu}}"
        },
        {
          "expr": "(DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} + DCGM_FI_DEV_FB_FREE{instance=~\"$instance\"}) / 1024",
          "legendFormat": "Total — GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "GPU Memory Usage (%)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "(DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} / (DCGM_FI_DEV_FB_USED{instance=~\"$instance\"} + DCGM_FI_DEV_FB_FREE{instance=~\"$instance\"})) * 100",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "GPU Temperature (°C)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_TEMP{instance=~\"$instance\"}",
          "legendFormat": "GPU {{gpu}} — {{instance}}"
        }
      ]
    },
    {
      "title": "GPU Power Draw (W)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt"
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_POWER_USAGE{instance=~\"$instance\"}",
          "legendFormat": "GPU {{gpu}} — {{instance}}"
        }
      ]
    },
    {
      "title": "SM Clock (MHz)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "MHz" } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_SM_CLOCK{instance=~\"$instance\"}",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    },
    {
      "title": "Xid Errors",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_XID_ERRORS{instance=~\"$instance\"}",
          "legendFormat": "GPU {{gpu}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["gpu", "nvidia", "dcgm", "genai"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(DCGM_FI_DEV_GPU_UTIL, instance)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "NVIDIA GPU — DCGM Metrics",
  "uid": "nvidia-gpu-dcgm"
}
