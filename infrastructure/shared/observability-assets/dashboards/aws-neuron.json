{
  "annotations": { "list": [] },
  "description": "AWS Neuron SDK metrics for Inferentia2/Trainium — NeuronCore utilization, device memory, execution latency, errors",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "NeuronCore Utilization (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 * neuroncore_utilization_ratio{instance=~\"$instance\"}",
          "legendFormat": "Core {{neuroncore}} — {{instance}}"
        }
      ]
    },
    {
      "title": "Device Memory Used (GiB)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes"
        }
      },
      "targets": [
        {
          "expr": "neuron_runtime_memory_used_bytes{instance=~\"$instance\",memory_location=\"neuron_device\"} / 1073741824",
          "legendFormat": "Neuron device — {{instance}}"
        },
        {
          "expr": "neuron_runtime_memory_used_bytes{instance=~\"$instance\",memory_location=\"host\"} / 1048576",
          "legendFormat": "Host runtime (MiB) — {{instance}}"
        }
      ]
    },
    {
      "title": "Neuron Device Memory Used (GiB)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 14 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "neuron_runtime_memory_used_bytes{instance=~\"$instance\",memory_location=\"neuron_device\"} / 1073741824",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "title": "Host Runtime Memory Used (MiB)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "mebibytes"
        }
      },
      "targets": [
        {
          "expr": "neuron_runtime_memory_used_bytes{instance=~\"$instance\",memory_location=\"host\"} / 1048576",
          "legendFormat": "Host runtime — {{instance}}"
        }
      ]
    },
    {
      "title": "Neuron Monitor Scrape Up",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "up{service=\"neuron-monitor\",instance=~\"$instance\"}",
          "legendFormat": "Up — {{instance}}"
        }
      ]
    },
    {
      "title": "NeuronCore Utilization by Core (%)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "100 * neuroncore_utilization_ratio{instance=~\"$instance\"}",
          "legendFormat": "Core {{neuroncore}}"
        }
      ]
    },
    {
      "title": "Neuron Runtime Memory by Location",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes"
        }
      },
      "targets": [
        {
          "expr": "neuron_runtime_memory_used_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{memory_location}} — {{instance}}"
        }
      ]
    },
    {
      "title": "Neuron Metrics Target",
      "type": "table",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "up{service=\"neuron-monitor\",instance=~\"$instance\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "Time": true, "Value": true },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["neuron", "inferentia", "trainium", "aws", "genai"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(neuroncore_utilization_ratio, instance)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AWS Neuron — Inferentia/Trainium Metrics",
  "uid": "aws-neuron-metrics"
}
