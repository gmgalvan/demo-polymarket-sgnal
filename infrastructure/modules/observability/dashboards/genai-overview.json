{
  "annotations": { "list": [] },
  "description": "GenAI platform overview — combines GPU utilization, vLLM inference, Karpenter scaling, and cost metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Platform Status",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "GPU Nodes Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(kube_node_labels{label_workload=\"gpu\"})",
          "legendFormat": "GPU nodes"
        }
      ]
    },
    {
      "title": "Inferentia Nodes Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(kube_node_labels{label_workload=\"neuron\"})",
          "legendFormat": "Inferentia nodes"
        }
      ]
    },
    {
      "title": "ARM (Core) Nodes Active",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(kube_node_labels{label_workload=\"core\"})",
          "legendFormat": "Core nodes"
        }
      ]
    },
    {
      "title": "vLLM Instances Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(up{job=~\".*vllm.*\"} == 1)",
          "legendFormat": "vLLM pods"
        }
      ]
    },
    {
      "title": "Total Requests Waiting",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(vllm:num_requests_waiting) or vector(0)",
          "legendFormat": "Waiting"
        }
      ]
    },
    {
      "title": "Avg GPU Utilization",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 20 },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "avg(DCGM_FI_DEV_GPU_UTIL) or vector(0)",
          "legendFormat": "Avg util"
        }
      ]
    },
    {
      "title": "Inference Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "title": "TTFT P50 / P95 (all instances)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "TTFT P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_to_first_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "TTFT P95"
        }
      ]
    },
    {
      "title": "TPOT P50 / P95 (all instances)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vllm:time_per_output_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "TPOT P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vllm:time_per_output_token_seconds_bucket[5m])) by (le))",
          "legendFormat": "TPOT P95"
        }
      ]
    },
    {
      "title": "Total Token Throughput",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "displayName": "tok/s" } },
      "targets": [
        {
          "expr": "sum(rate(vllm:prompt_tokens_total[5m]))",
          "legendFormat": "Prompt tok/s"
        },
        {
          "expr": "sum(rate(vllm:generation_tokens_total[5m]))",
          "legendFormat": "Generation tok/s"
        }
      ]
    },
    {
      "title": "Hardware & Scaling",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false
    },
    {
      "title": "GPU Utilization by Node",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "GPU {{gpu}} — {{instance}}"
        }
      ]
    },
    {
      "title": "GPU Memory Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "targets": [
        {
          "expr": "(DCGM_FI_DEV_FB_USED / (DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE)) * 100",
          "legendFormat": "GPU {{gpu}} — {{instance}}"
        }
      ]
    },
    {
      "title": "Karpenter Node Pool Sizing",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "karpenter_nodepools_allowed_disruptions",
          "legendFormat": "Allowed disruptions — {{nodepool}}"
        },
        {
          "expr": "karpenter_nodes_total_daemon_requests{resource_type=\"cpu\"}",
          "legendFormat": "Daemon CPU — {{nodepool}}"
        }
      ]
    },
    {
      "title": "Pending Pods (Karpenter triggers)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum by (namespace) (kube_pod_status_phase{phase=\"Pending\"})",
          "legendFormat": "Pending — {{namespace}}"
        }
      ]
    },
    {
      "title": "Logs (Loki)",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false
    },
    {
      "title": "Recent vLLM Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "targets": [
        {
          "expr": "{namespace=~\".*\", container=~\"vllm.*\"} |= ``",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["genai", "overview", "gpu", "vllm", "karpenter"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus"
      },
      {
        "name": "loki_datasource",
        "type": "datasource",
        "query": "loki"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GenAI Platform Overview",
  "uid": "genai-platform-overview"
}
