[Unit]
Description=vLLM OpenAI-compatible server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user
Environment=HOME=/home/ec2-user
EnvironmentFile=/opt/vllm/vllm.env
ExecStart=/opt/vllm/.venv/bin/vllm serve ${vllm_model_id} --host 127.0.0.1 --port ${vllm_port} --api-key ${vllm_api_key} --served-model-name ${vllm_served_model_name} --quantization awq_marlin --dtype auto --gpu-memory-utilization ${vllm_gpu_memory_utilization} --max-model-len ${vllm_max_model_len} --enable-auto-tool-choice --tool-call-parser hermes
Restart=always
RestartSec=10
StandardOutput=append:/var/log/vllm.log
StandardError=append:/var/log/vllm.log

[Install]
WantedBy=multi-user.target
