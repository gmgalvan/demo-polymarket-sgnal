#!/bin/bash
set -euxo pipefail

dnf install -y git openssl
install -d -m 0755 /opt/openclaw-demo /opt/vllm
install -d -m 0700 -o ec2-user -g ec2-user /home/ec2-user/.openclaw-bootstrap
touch /var/log/openclaw-install.log /var/log/openclaw-onboard.log /var/log/vllm.log /var/log/openclaw-vllm-models.log
chown ec2-user:ec2-user /var/log/openclaw-install.log /var/log/openclaw-onboard.log /var/log/vllm.log /var/log/openclaw-vllm-models.log

if [ -n "${gateway_token}" ]; then
  GATEWAY_TOKEN_VALUE=${jsonencode(gateway_token)}
else
  GATEWAY_TOKEN_VALUE="$(openssl rand -hex 24)"
fi

cat <<EOF_ENV >/opt/openclaw-demo/openclaw.env
export OPENCLAW_GATEWAY_TOKEN="$${GATEWAY_TOKEN_VALUE}"
EOF_ENV
chmod 600 /opt/openclaw-demo/openclaw.env

cp /opt/openclaw-demo/openclaw.env /home/ec2-user/.openclaw-bootstrap/openclaw.env
chown ec2-user:ec2-user /home/ec2-user/.openclaw-bootstrap/openclaw.env
chmod 600 /home/ec2-user/.openclaw-bootstrap/openclaw.env

cat <<'EOF_VLLM_INSTALL' | base64 -d >/opt/vllm/install-vllm.sh
${install_vllm_sh_b64}
EOF_VLLM_INSTALL

cat <<'EOF_VLLM_SERVICE' | base64 -d >/etc/systemd/system/vllm.service
${vllm_service_b64}
EOF_VLLM_SERVICE

cat <<'EOF_OC_INSTALL' | base64 -d >/opt/openclaw-demo/install-openclaw.sh
${install_openclaw_sh_b64}
EOF_OC_INSTALL

cat <<'EOF_OC_CONFIG' | base64 -d >/opt/openclaw-demo/configure-openclaw.sh
${configure_openclaw_sh_b64}
EOF_OC_CONFIG

chmod 755 /opt/vllm/install-vllm.sh /opt/openclaw-demo/install-openclaw.sh /opt/openclaw-demo/configure-openclaw.sh

/opt/vllm/install-vllm.sh > /var/log/vllm-install.log 2>&1
systemctl daemon-reload
systemctl enable --now vllm.service

VLLM_READY=0
for _ in $(seq 1 240); do
  if curl -fsS -H "Authorization: Bearer ${vllm_api_key}" "http://127.0.0.1:${vllm_port}/v1/models" >/dev/null; then
    VLLM_READY=1
    break
  fi
  sleep 5
done

if [ "$${VLLM_READY}" -ne 1 ]; then
  echo "vLLM did not become ready in time" >&2
  systemctl status vllm.service || true
  exit 1
fi

loginctl enable-linger ec2-user || true
su - ec2-user -c 'bash -lc "/opt/openclaw-demo/install-openclaw.sh > /var/log/openclaw-install.log 2>&1"'
su - ec2-user -c 'bash -lc "/opt/openclaw-demo/configure-openclaw.sh > /var/log/openclaw-onboard.log 2>&1"'
