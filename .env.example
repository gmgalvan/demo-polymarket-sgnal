# === LOCAL DEV ===
# Model: Anthropic directly via LiteLLM
ANTHROPIC_API_KEY=sk-ant-...
# USE_MCP=false   # set false if MCP servers are not running

# === EKS (replaces the above) ===
# Model: LiteLLM gateway pointing to vLLM
# MODEL_PROVIDER=litellm_proxy
# LITELLM_API_BASE=http://litellm-gateway:4000
# LITELLM_API_KEY=sk-litellm-...
# REASONING_MODEL=llama-3.1-70b
# FAST_MODEL=llama-3.1-8b

# === WATCHDOG (Phase 3) ===
# WATCHDOG_MODE=mock
# WATCHDOG_MOCK_INTERVAL_SECONDS=5
# WATCHDOG_ASSET=BTC
# WATCHDOG_TIMEFRAME=15min
# WATCHDOG_BANKROLL=1000
# WATCHDOG_TASK_PROMPT=Analyze the current BTC 15min candle and determine if there is a positive EV opportunity.

# Binance WS (used in WATCHDOG_MODE=websocket)
# BINANCE_SYMBOL=btcusdt
# BINANCE_INTERVAL=15m
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_15m

# Polymarket WS
# POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# POLYMARKET_WS_SUBSCRIBE={"assets_ids":["<YES_TOKEN_ID>","<NO_TOKEN_ID>"],"type":"market","custom_feature_enabled":true}
# POLYMARKET_AUTO_SUBSCRIBE=true
# POLYMARKET_SEARCH_URL=https://gamma-api.polymarket.com/public-search
# POLYMARKET_SEARCH_QUERY=bitcoin
# POLYMARKET_DEFAULT_ODDS=2.0
# VOLATILITY_SPIKE_THRESHOLD=0.005
# WATCHDOG_RECONNECT_DELAY_SECONDS=2

# === OTHER KEYS ===
# TAVILY_API_KEY=         # for web_search MCP server
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
