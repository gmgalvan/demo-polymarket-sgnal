# === LOCAL DEV ===
# Model: Anthropic directly via LiteLLM
ANTHROPIC_API_KEY=sk-ant-...
# USE_MCP=false   # set false if MCP servers are not running

# === EKS (replaces the above) ===
# Model: LiteLLM gateway pointing to vLLM
# MODEL_PROVIDER=litellm_proxy
# LITELLM_API_BASE=http://litellm-gateway:4000
# LITELLM_API_KEY=sk-litellm-...
# REASONING_MODEL=llama-3.1-70b
# FAST_MODEL=llama-3.1-8b
# STRATEGIST_MAX_TOKENS=768

# === WATCHDOG (Phase 3) ===
# WATCHDOG_MODE=mock
# WATCHDOG_MOCK_INTERVAL_SECONDS=5
# WATCHDOG_ASSET=BTC
# WATCHDOG_TIMEFRAME=5min
# WATCHDOG_BANKROLL=1000
# WATCHDOG_TASK_PROMPT=Analyze the current BTC candle and determine if there is a positive EV opportunity.

# Market data provider (used in WATCHDOG_MODE=websocket)
# MARKET_DATA_PROVIDER=coinbase   # coinbase | binance
#
# Coinbase WS (default)
# COINBASE_PRODUCT_ID=BTC-USD
# COINBASE_WS_URL=wss://advanced-trade-ws.coinbase.com
#
# Binance WS (optional fallback)
# BINANCE_SYMBOL=btcusdt
# BINANCE_INTERVAL=15m
# BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@kline_15m

# Polymarket WS
# POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# POLYMARKET_WS_SUBSCRIBE={"assets_ids":["<YES_TOKEN_ID>","<NO_TOKEN_ID>"],"type":"market","custom_feature_enabled":true}
# POLYMARKET_AUTO_SUBSCRIBE=true
# POLYMARKET_EVENT_URL=https://polymarket.com/event/btc-updown-15m-1773362700  # optional explicit event URL/slug (priority over auto)
# POLYMARKET_SEARCH_URL=https://gamma-api.polymarket.com/public-search
# POLYMARKET_MARKETS_URL=https://gamma-api.polymarket.com/markets
# POLYMARKET_SEARCH_QUERY=bitcoin
# POLYMARKET_DEFAULT_ODDS=2.0
#
# Rolling slug discovery (recommended for short-horizon markets):
# POLYMARKET_SLUG_PATTERN=btc-updown-15m   # computes slug btc-updown-15m-{unix_ts} aligned to 15min windows
#                                           # auto-computes refresh interval (window × 0.9)
#                                           # also supports btc-updown-5m for 5-minute markets
# POLYMARKET_EVENTS_URL=https://gamma-api.polymarket.com/events
#
# VOLATILITY_SPIKE_THRESHOLD=0.005
# WATCHDOG_RECONNECT_DELAY_SECONDS=2
# WATCHDOG_ENFORCE_EDGE_GUARD=true   # set false for demo to always run Strategist LLM
# WATCHDOG_COINBASE_5MIN_ASSETS=BTC,ETH,SOL  # empty/unset -> enforce 5min for all Coinbase assets
# POLYMARKET_MARKET_REFRESH_SECONDS=810  # reconnect every N seconds to pick up rolling short-horizon markets
#                                         # auto-computed from POLYMARKET_SLUG_PATTERN when not set; 0 = disabled

# === RAG / VECTOR DB (Phase 4) ===
# USE_RAG=false              # set true to enable RAG (run ingest_context.py first)
# VECTOR_BACKEND=chroma      # local: chroma | EKS: opensearch
#
# ChromaDB — server mode (docker compose up chromadb):
# CHROMA_HOST=localhost
# CHROMA_PORT=8004
#
# ChromaDB — in-process mode (no docker, default):
# CHROMA_PATH=./data/chroma
#
# Amazon OpenSearch Service (EKS only — managed AWS service):
# OPENSEARCH_HOST=search-my-domain.us-east-1.es.amazonaws.com
# OPENSEARCH_PORT=443
# OPENSEARCH_INDEX=market_context
#
# Embeddings via LiteLLM gateway (same gateway used for chat — no extra infra):
# EMBEDDING_MODEL=nomic-embed-text   # or text-embedding-ada-002, amazon.titan-embed-text-v2:0
# (LITELLM_API_BASE and LITELLM_API_KEY already set above)

# === EXECUTION MODEL (optional) ===
# USE_LMSR=false             # set true to apply LMSR slippage adjustment in Broadcaster
# LMSR_LIQUIDITY_B=5000      # higher = deeper liquidity (lower slippage)

# === OTHER KEYS ===
# TAVILY_API_KEY=         # for web_search MCP server
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
